{
  "name": "@volcano822/spec-workflow-cli",
  "version": "1.0.0",
  "description": "CLI for spec-driven development workflow",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "spec-workflow": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc && chmod +x dist/index.js",
    "clean": "node -e \"import('fs').then(fs => { try { if (fs.existsSync('dist')) fs.rmSync('dist', { recursive: true, force: true }); } catch(e) {} })\"",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "spec-workflow",
    "ai-development",
    "development-workflow",
    "project-management",
    "cli"
  ],
  "author": "",
  "license": "GPL-3.0",
  "dependencies": {
    "simple-git": "^3.28.0",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@types/node": "^22.18.1",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.0"
  }
}
